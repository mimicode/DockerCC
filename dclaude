#!/usr/bin/env bash
# dclaude - Docker 隔离运行 claude-code
#
# 用法:
#   dclaude                    # 默认环境
#   dclaude -e go120          # Go 1.20 环境
#   dclaude -e php74          # PHP 7.4 环境
#   dclaude -e nodejs          # Node.js 环境
#   dclaude -e go120,nodejs    # 组合环境
#   dclaude -e go120 -- --model claude-opus-4-7  # 透传参数

set -e

IMAGE_NAME="claude-cc"
CLAUDE_CONFIG="${HOME}/.claude"

# 解析参数
ENV_TAG="latest"
PASS_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--env)
      ENV_TAG="$2"
      shift 2
      ;;
    --)
      shift
      PASS_ARGS+=("$@")
      break
      ;;
    *)
      PASS_ARGS+=("$1")
      shift
      ;;
  esac
done

# 转换为绝对路径（兼容 Windows Git Bash）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORK_DIR="$(pwd)"

# 如果指定了环境且镜像不存在，先构建
if [ "$ENV_TAG" != "latest" ] && ! docker image inspect "${IMAGE_NAME}:${ENV_TAG}" &>/dev/null; then
  echo "镜像 ${IMAGE_NAME}:${ENV_TAG} 不存在，正在构建..."
  docker build \
    --build-arg INSTALL_ENVS="$ENV_TAG" \
    -t "${IMAGE_NAME}:${ENV_TAG}" \
    "$SCRIPT_DIR"
fi

# 获取当前用户信息（用于容器内以相同用户运行）
CURRENT_USER="$(whoami)"
CURRENT_UID="$(id -u)"
CURRENT_GID="$(id -g)"

# 运行容器
exec docker run -it --rm \
  -v "${WORK_DIR}:/workspace" \
  -v "${CLAUDE_CONFIG}:/home/claude/.claude" \
  -e ANTHROPIC_API_KEY \
  --user "${CURRENT_UID}:${CURRENT_GID}" \
  --env HOME=/home/claude \
  -w /workspace \
  "${IMAGE_NAME}:${ENV_TAG}" \
  claude --dangerously-skip-permissions "${PASS_ARGS[@]}"
